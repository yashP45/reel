{
  "name": "reel-extension",
  "description": "Reel — Record & Share. A Loom-style Chrome extension with faster UX.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@wxt-dev/module-react": "^1.1.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
